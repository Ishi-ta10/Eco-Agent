# =============================
# Eco-Agent demo environment
# Copy this file to .env and fill with your own values.
# Do NOT commit real credentials.
# =============================

# ---- SMTP settings (used by scheduler email pipelines) ----
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USERNAME=sender@company.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=sender@company.com

# Alternate scheduler SMTP variable names (API path compatibility)
SMTP_SERVER=smtp.gmail.com
SMTP_USE_TLS=True
SMTP_TIMEOUT=10
SENDER_EMAIL=sender@company.com
SENDER_PASSWORD=your_app_password
DEFAULT_RECIPIENT_EMAIL=recipient@company.com

# ---- Frontend ----
VITE_API_URL=http://localhost:8000
