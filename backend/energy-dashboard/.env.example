# Primary SMTP variables (mail_scheduling_agent)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USERNAME=sender@company.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=sender@company.com

# API scheduler compatibility variables (backend/api/services/scheduler_service.py)
SMTP_SERVER=smtp.gmail.com
SMTP_USE_TLS=True
SMTP_TIMEOUT=10
SENDER_EMAIL=sender@company.com
SENDER_PASSWORD=your_app_password
DEFAULT_RECIPIENT_EMAIL=recipient@company.com
