SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USERNAME=sender@company.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=sender@company.com

# Grid data SharePoint auth (optional)
# GRID_DATA_AUTH_MODE: auto | none | bearer | cookie | both
GRID_DATA_AUTH_MODE=auto
GRID_DATA_BEARER_TOKEN=
GRID_DATA_COOKIE=
GRID_DATA_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64)
